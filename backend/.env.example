GITHUB_TOKEN=Your GitHub token goes here
OPEN_AI_KEY=Your OpenAI API key goes here
ANTHROPIC_KEY=Your Anthropic API key goes here
DATABASE_URL=Your database URL goes here (e.g., postgresql://username:password@localhost:5432/database_name)
JWT_SECRET=Your JWT secret key goes here
GITHUB_CLIENT_ID=Your GitHub client ID goes here
