# --- API Keys ---
GITHUB_TOKEN=                        # Optional. Server-level GitHub token used as fallback for public repo ingestion and share-link file viewing. Not required if all users authenticate with repo access.
OPEN_AI_KEY=                         # OpenAI API key (used for embeddings)
ANTHROPIC_KEY=                       # Anthropic API key (used for chat responses)

# --- Database ---
DATABASE_URL=                        # e.g. postgresql://username:password@localhost:5432/database_name

# --- Authentication / OAuth ---
JWT_SECRET=                          # Random secret for signing JWTs (e.g. openssl rand -base64 32)
JWT_ALGORITHM=HS256                  # JWT signing algorithm
JWT_EXPIRE_MINUTES=10080             # Token lifetime in minutes (default: 7 days)
GITHUB_CLIENT_ID=                    # GitHub OAuth app client ID
GITHUB_CLIENT_SECRET=                # GitHub OAuth app client secret

# --- URLs ---
FRONTEND_URL=http://localhost:5173   # URL of the frontend (used for OAuth redirects)
REDIS_URL=redis://localhost:6379     # Redis connection URL

# --- Session Limits ---
MAX_SESSIONS_PER_USER=5             # Max saved chat sessions per user
MAX_CHARACTERS_PER_QUESTION=1000    # Max length of a user question
MAX_CHARACTERS_PER_TITLE=100        # Max length of a session title

# --- Repository Processing ---
MAX_FILE_SIZE_BYTES=100000          # Skip files larger than this (default: 100 KB)
MAX_FILES_PER_REPO=2000             # Stop fetching after this many files
MAX_REPO_SIZE_KB=500000             # Reject repos larger than this (default: ~500 MB)

# --- Embedding ---
EMBEDDING_MODEL=text-embedding-3-small  # OpenAI embedding model
EMBEDDING_DIMENSIONS=1536               # Embedding vector size (must match model)
TOP_K_CHUNKS=5                          # Number of code chunks injected per chat prompt

# --- LLM ---
ANTHROPIC_MODEL=claude-haiku-4-5    # Anthropic model for chat responses
MAX_RESPONSE_TOKENS=1024            # Max tokens the LLM can generate per response
TEMPERATURE=0.7                     # Response randomness (0.0 = deterministic, 1.0 = creative)
